---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="stylesheet" href="/fonts/cairo.css" />
		<link rel="stylesheet" href="/icons/fontawesome.css" />
	</head>
	<body class="bg-[#07111e] text-[#c9d4e5] font-cairo antialiased min-h-screen">
		<slot />
        
        <style is:global>
            /* قواعد الأمان البصرية الأساسية (Global CSS) */
            ::-webkit-scrollbar {
                width: 8px;
            }
            ::-webkit-scrollbar-track {
                background: #07111e;
            }
            ::-webkit-scrollbar-thumb {
                background: #dfb76c;
                border-radius: 4px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: #bfa15f;
            }
            .glassmorphism {
                background: rgba(13, 30, 54, 0.75);
                backdrop-filter: blur(14px);
                border: 1px solid rgba(223, 183, 108, 0.12);
                box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.4);
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .glassmorphism:hover {
                border-color: rgba(223, 183, 108, 0.35);
                box-shadow: 0 12px 40px 0 rgba(223, 183, 108, 0.08);
                transform: translateY(-6px);
            }
        </style>
	</body>
</html>
