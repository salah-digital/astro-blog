            <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
                <span class="text-sm font-bold text-gold-600 dark:text-gold-400 tracking-wider block">خدماتنا الاستشارية</span>
                <h2 id="servicesSectionTitle" class="text-3xl sm:text-4xl font-extrabold text-primary-950 dark:text-white">حلول متكاملة تضمن لك التفوق والريادة الرقمية</h2>
                <p id="servicesSectionDesc" class="text-slate-600 dark:text-slate-400 text-sm sm:text-base">نصمم خدماتنا بدقة لتلائم تطلعات واحتياجات المؤسسات الطموحة في العصر الرقمي المتسارع.</p>
            </div>

            <!-- Services Grid -->
            <div id="dynamicServicesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Managed and injected via JavaScript state -->
            </div>
        </div>
    </section>

    <!-- Articles & Blog Section (CMS DRIVEN) -->
    <section id="articles" class="py-20 bg-white dark:bg-primary-900/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
                <span class="text-sm font-bold text-gold-600 dark:text-gold-400 tracking-wider block">المقالات والأبحاث الاستشارية</span>
                <h2 class="text-3xl sm:text-4xl font-extrabold text-primary-950 dark:text-white">رؤى وأبحاث في السيادة والسمعة الرقمية</h2>
