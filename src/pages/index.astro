        // Digital Maturity Quiz Logic
        function nextQuizStep(step, points) {
            quizScore += points;
            
            // Hide current step
            const currentStepEl = document.querySelector(`.quiz-step[data-step="${step}"]`);
            if (currentStepEl) currentStepEl.classList.add('hidden');
            
            const nextStep = step + 1;
            const progressPercentage = (nextStep / 5) * 100;
            document.getElementById('quizProgress').style.width = `${progressPercentage}%`;

            if (nextStep <= 5) {
                // Show next step
                const nextStepEl = document.querySelector(`.quiz-step[data-step="${nextStep}"]`);
                if (nextStepEl) nextStepEl.classList.remove('hidden');
            } else {
                // Show results page
                showQuizResults();
            }
        }

        // Dynamic result calculation based on score
        function showQuizResults() {
            document.getElementById('quizResult').classList.remove('hidden');
            document.getElementById('quizScoreDisplay').textContent = quizScore;
            
            const levelTitle = document.getElementById('resultLevelTitle');
            const levelDesc = document.getElementById('resultLevelDesc');
            const resultAdvice = document.getElementById('resultAdvice');
            
            if (quizScore >= 12) {
                levelTitle.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-500"></i>مستوى متقدم (نضج رائد)`;
                levelDesc.textContent = "تمتلك مؤسستك أساسات تكنولوجية قوية وثقافة عمل مرنة تتكيف سريعاً مع بروتوكولات السيادة الرقمية والذكاء الاصطناعي وحماية السمعة.";
                resultAdvice.textContent = "ركز الآن مع مكتبنا على الابتكار الاستباقي وحماية البنية السيبرانية من التهديدات الخارجية لضمان السيطرة والهيمنة الكاملة على السمعة المؤسسية لشركتك.";
            } else if (quizScore >= 7) {
                levelTitle.innerHTML = `<i class="fa-solid fa-circle-exclamation text-amber-500"></i>مستوى متوسط (نضج ناشئ)`;
                levelDesc.textContent = "تستخدم بعض الحلول التقنية ولكن هناك فجوات في ربط البيانات وحوكمتها مما يعرض السمعة المؤسسية لثغرات غير مرغوبة.";
