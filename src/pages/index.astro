                        gold: {
                            100: '#fdf9eb',
                            200: '#fbf0cc',
                            300: '#f5de99',
                            400: '#ecc45d',
                            500: '#deaa33',
                            600: '#c58b26',
                            700: '#a36b20',
                            800: '#85541f',
                            950: '#44260a',
