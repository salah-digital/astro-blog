        // Live Chat Assistant (Gemini API Integration with Exponential Backoff)
        async function fetchGeminiWithBackoff(userQuery, systemPrompt) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: userQuery }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };
            
            let delay = 1000;
            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (response.ok) {
                        return await response.json();
                    }
                } catch (e) {
                    // Backoff retries
                }
                await new Promise(resolve => setTimeout(resolve, delay));
                delay *= 2;
            }
            throw new Error("فشل الاتصال بخدمة الذكاء الاصطناعي بعد عدة محاولات.");
        }

        async function handleChatSubmit(e) {
            e.preventDefault();
            const inputEl = document.getElementById('chatInput');
            const query = inputEl.value.trim();
            if (!query) return;

            // Clear input
            inputEl.value = '';

            // Render user message
            appendChatMessage(query, 'user');

            // Render temporary waiting placeholder response
            const placeholderId = appendChatMessage('قيد التفكير وتوليد النصائح الاستشارية والمحاكاة...', 'bot-loading');

            const systemPrompt = `أنت المساعد الرقمي الافتراضي والتوأم الذكي لمكتب المستشار صلاح حسن إبراهيم للاستشارات والتطوير الرقمي. اسمك 'مستشار صلاح الرقمي'. أنت خبير في السيادة الرقمية وإدارة السمعة المؤسسية والأمن السيبراني في العراق والوطن العربي. تحدث بلغة استشارية راقية، ملهمة، واحترافية باللغة العربية. قدم إرشادات ونقاط نصائح عملية في استراتيجيات الإدارة والتحول الرقمي والتقنية والسمعة المؤسسية استناداً لخبرة واسعة. شجع العميل على حجز موعد مع المستشار الحقيقي 'صلاح حسن إبراهيم' لمراجعة أعمق وتطبيق عملي من خلال النماذج والوسائل المتاحة بالموقع أو التواصل الفوري عبر الواتساب المتاح بالموقع على الرقم ${siteData.contact.whatsapp} أو هاتف المكتب المباشر ${siteData.contact.phone} أو إرسال بريد إلكتروني إلى ${siteData.contact.email}، ومقرنا هو العراق - بغداد.`;

            try {
                const responseData = await fetchGeminiWithBackoff(query, systemPrompt);
                const answerText = responseData.candidates?.[0]?.content?.parts?.[0]?.text || "نأسف، لم نتمكن من الحصول على رد مناسب حالياً. يرجى المحاولة لاحقاً.";
                
                removeMessageElement(placeholderId);
                appendChatMessage(answerText, 'bot');
            } catch (err) {
                removeMessageElement(placeholderId);
                appendChatMessage(`عذراً، يبدو أن هناك ضغطاً مؤقتاً على خوادم الذكاء الاصطناعي. تفضل بالتواصل معنا عبر واتساب المكتب المباشر ${siteData.contact.whatsapp} أو اترك رسالتك بطلب الاستشارة بالأسفل لحجز موعد استثنائي مجاني.`, 'bot-error');
            }
        }

        function appendChatMessage(text, sender) {
            const container = document.getElementById('chatMessages');
            const msgId = 'msg-' + Date.now() + Math.random().toString(36).substr(2, 4);

            const wrapper = document.createElement('div');
            wrapper.id = msgId;
            wrapper.className = 'flex items-start gap-3 max-w-[85%] ' + (sender === 'user' ? 'mr-auto flex-row-reverse' : 'ml-auto');

            let avatar = '';
            let bubbleClass = '';
            
            if (sender === 'user') {
                avatar = `<div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-800 dark:text-white flex items-center justify-center shrink-0"><i class="fa-solid fa-user text-sm"></i></div>`;
                bubbleClass = `bg-gold-500 text-white rounded-2xl rounded-tl-none p-4 shadow-sm border border-gold-600`;
            } else {
                avatar = `<div class="w-8 h-8 rounded-full bg-gold-600 text-white flex items-center justify-center shrink-0"><i class="fa-solid fa-user-tie text-sm"></i></div>`;
                if (sender === 'bot-loading') {
                    bubbleClass = `bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border border-primary-200 dark:border-primary-800 shadow-sm text-slate-400 italic animate-pulse`;
                } else if (sender === 'bot-error') {
                    bubbleClass = `bg-red-50 dark:bg-red-950/20 p-4 rounded-2xl rounded-tr-none border border-red-200 dark:border-red-900 shadow-sm text-red-500 text-xs`;
                } else {
                    bubbleClass = `bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border border-primary-200 dark:border-primary-800 shadow-sm text-slate-800 dark:text-slate-100`;
                }
            }

            wrapper.innerHTML = `
                ${avatar}
                <div class="${bubbleClass}">
                    <p class="text-sm leading-relaxed">${text}</p>
                    <span class="block text-[10px] text-slate-400 mt-2 text-left">الآن</span>
                </div>
            `;

            container.appendChild(wrapper);
            container.scrollTop = container.scrollHeight;
            return msgId;
        }

        function removeMessageElement(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        function clearChat() {
            const container = document.getElementById('chatMessages');
            container.innerHTML = `
                <div class="flex items-start gap-3 max-w-[85%]">
                    <div class="w-8 h-8 rounded-full bg-gold-600 text-white flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-user-tie text-sm"></i>
                    </div>
                    <div class="bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border border-primary-200 dark:border-primary-800 shadow-sm">
                        <p class="text-sm leading-relaxed text-slate-800 dark:text-slate-100">
                            مرحباً بك مجدداً في مكتب المستشار صلاح حسن إبراهيم. تم تفريغ سجل المحادثة بنجاح، ويسعدني الإجابة عن أي استشارات فنية أو إدارية جديدة ترغب بها. تفضل بطلبك الاستشاري الآن.
                        </p>
                        <span class="block text-[10px] text-slate-400 mt-2 text-left">الآن</span>
                    </div>
                </div>
            `;
        }
    </script>
