                <a href="#estimator" class="hover:text-gold-600 dark:hover:text-gold-400 font-semibold transition-colors">حاسبة الاستشارات</a>
                <a href="#ai-consultant" class="hover:text-gold-600 dark:hover:text-gold-400 font-semibold transition-colors">المستشار الذكي</a>
