    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#f5f7fa',
                            100: '#e4e8ee',
                            200: '#ccd5e0',
                            300: '#a7b8cc',
                            400: '#7c96b3',
                            500: '#5c7899',
                            600: '#48607f',
                            700: '#3c4e68',
                            800: '#344257',
                            900: '#2e3a4b',
                            950: '#1e2531',
