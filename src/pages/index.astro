        function triggerDeleteService(id) {
            showConfirmModal(
                "حذف خدمة استشارية؟", 
                "هل أنت متأكد من رغبتك في حذف هذه الخدمة؟ لن تظهر مجدداً في خيارات الحاسبة والطلب.",
