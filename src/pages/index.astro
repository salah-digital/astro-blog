    <!-- Interactive Feature 1: Digital Maturity Assessment Tool -->
    <section id="assessment" class="py-20 bg-primary-100/30 dark:bg-primary-950/40">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-2xl mx-auto mb-12 space-y-3">
                <span class="text-sm font-bold text-gold-600 dark:text-gold-400 block"><i class="fa-solid fa-gauge-high ml-1"></i>تقييم فوري</span>
                <h2 class="text-3xl font-extrabold text-primary-950 dark:text-white">مقياس النضج الرقمي للمؤسسات</h2>
                <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400">أجب عن 5 أسئلة سريعة لمعرفة مستوى استعداد مؤسستك للتحول الرقمي والحصول على توصيات استشارية أولية فورية من المستشار.</p>
            </div>

            <!-- Quiz Container -->
            <div class="bg-white dark:bg-primary-900 border border-primary-200 dark:border-primary-800 rounded-3xl p-6 sm:p-10 shadow-xl relative overflow-hidden">
                <!-- Progress Bar -->
                <div class="w-full bg-primary-100 dark:bg-primary-950 h-2 rounded-full mb-8">
                    <div id="quizProgress" class="bg-gradient-to-r from-gold-500 to-amber-500 h-2 rounded-full transition-all duration-300" style="width: 20%;"></div>
                </div>

                <!-- Questions Area -->
                <div id="quizWindow">
                    <!-- Question 1 -->
                    <div class="quiz-step active space-y-6" data-step="1">
                        <span class="text-gold-600 dark:text-gold-400 text-sm font-bold">السؤال 1 من 5</span>
                        <h3 class="text-lg sm:text-xl font-bold text-primary-950 dark:text-white">هل تمتلك مؤسستك موقعاً إلكترونياً أو تطبيقاً تفاعلياً لخدمة العملاء؟</h3>
