        // Active Application State (Pulls from LocalStorage or template)
        let siteData = {};
        let isAdminLoggedIn = false; // Auth Guard State

        // Load CMS Site data
        function loadSiteState() {
            const savedState = localStorage.getItem('salah_office_cms_state');
            if (savedState) {
                try {
                    siteData = JSON.parse(savedState);
                } catch (e) {
                    siteData = JSON.parse(JSON.stringify(DEFAULT_SITE_DATA));
                }
            } else {
                siteData = JSON.parse(JSON.stringify(DEFAULT_SITE_DATA));
            }
            renderAllCmsElements();
        }

