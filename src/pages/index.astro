        // Import data backup JSON
        function importSiteBackup() {
            const fileInput = document.getElementById('importJsonFileInput');
            const file = fileInput.files[0];
            if (!file) {
                showNotificationModal("لم يتم اختيار ملف", "يرجى تحديد ملف النسخة الاحتياطية بصيغة .json من جهازك أولاً.");
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const parsedData = JSON.parse(e.target.result);
                    // Minimal validation
                    if (parsedData.general && parsedData.services && parsedData.testimonials && parsedData.articles) {
                        siteData = parsedData;
                        localStorage.setItem('salah_office_cms_state', JSON.stringify(siteData));
                        renderAllCmsElements();
