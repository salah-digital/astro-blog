    <script is:inline>
        let appTheme = localStorage.getItem('theme') || 'light';
        let currentQuizStep = 1;
        let quizScore = 0;
        let selectedCompanyMultiplier = 1.0;
        let selectedCompanyLabel = "عيادة / شركة صاعدة";

        window.onload = function() {
            if (appTheme === 'dark') {
                document.documentElement.classList.add('dark');
                document.getElementById('themeIcon').className = 'fa-solid fa-sun';
            } else {
                document.documentElement.classList.remove('dark');
                document.getElementById('themeIcon').className = 'fa-solid fa-moon';
            }
            document.getElementById('currentYear').textContent = new Date().getFullYear();
            calculateCost();
        };

        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                document.getElementById('themeIcon').className = 'fa-solid fa-moon';
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                document.getElementById('themeIcon').className = 'fa-solid fa-sun';
                localStorage.setItem('theme', 'dark');
            }
        }

        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('hidden');
        }

        function nextQuizStep(step, points) {
            quizScore += points;
            const currentStepEl = document.querySelector(`.quiz-step[data-step="${step}"]`);
            if (currentStepEl) currentStepEl.classList.add('hidden');
            
            const nextStep = step + 1;
            const progressPercentage = (nextStep / 5) * 100;
            document.getElementById('quizProgress').style.width = `${progressPercentage}%`;

            if (nextStep <= 5) {
                const nextStepEl = document.querySelector(`.quiz-step[data-step="${nextStep}"]`);
                if (nextStepEl) nextStepEl.classList.remove('hidden');
            } else {
                showQuizResults();
            }
        }

        function showQuizResults() {
            document.getElementById('quizResult').classList.remove('hidden');
            document.getElementById('quizScoreDisplay').textContent = quizScore;
            
            const levelTitle = document.getElementById('resultLevelTitle');
            const levelDesc = document.getElementById('resultLevelDesc');
            const resultAdvice = document.getElementById('resultAdvice');
            
            if (quizScore >= 12) {
                levelTitle.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-500"></i>مستوى رائد (حصانة وسيادة كاملة)`;
                levelDesc.textContent = "تمتلك مؤسستك تحكماً ممتازاً بأصولها البرمجية المستقلة وتحفظ سيادتها بعيداً عن الاحتكار الخارجي.";
                resultAdvice.textContent = "استمر في تعزيز هذا التفوق وعزز أنظمتك بأدوات التحسين الجراحي (Surgical SEO) للسيطرة المستدامة على خرائط ومحركات البحث المحلية.";
            } else if (quizScore >= 7) {
                levelTitle.innerHTML = `<i class="fa-solid fa-circle-exclamation text-amber-500"></i>مستوى متوسط (نزيف رقمي ناشئ)`;
                levelDesc.textContent = "أصولك الرقمية مستأجرة جزئياً أو تقع تحت تحكم مبرمجين وسيطين، مما يعرض أمنك التنظيمي والمالي لتقلب السياسات.";
                resultAdvice.textContent = "ننصحك بالبدء فوراً ببروتوكول فك الارتباط ونقل الشفرات واستضافة منصتك بكود Astro مستقل لقطع الاشتراكات المتكررة وإنهاء النزيف.";
            } else {
                levelTitle.innerHTML = `<i class="fa-solid fa-triangle-exclamation text-red-500"></i>مستوى حرج (تبعية واختناق برمي كامل)`;
                levelDesc.textContent = "تعتمد كلياً على صفحات السوشيال ميديا أو أنظمة ثقيلة مغلقة، مما يعني أنك لا تملك أصولك الرقمية الحقيقية والمكالمات تتعثر باستمرار.";
                resultAdvice.textContent = "أنت بحاجة لتفعيل خطة إنقاذ وتوحيد فورية بالمكتب لبناء البنية التحتية السيادية وحصد المعرفات الجغرافية داخل العراق لإنقاذ التدفق المالي والاتصالات.";
            }
        }

        function resetQuiz() {
            quizScore = 0;
            document.getElementById('quizProgress').style.width = '20%';
            document.getElementById('quizResult').classList.add('hidden');
            document.querySelectorAll('.quiz-step').forEach(step => step.classList.add('hidden'));
            document.querySelector('.quiz-step[data-step="1"]').classList.remove('hidden');
        }

        function updateHoursRange(value) {
            document.getElementById('estHoursDisplay').textContent = value;
            calculateCost();
        }

        function setEstCompanySize(size, multiplier, element) {
            selectedCompanyMultiplier = multiplier;
            if (size === 'small') selectedCompanyLabel = "عيادة / شركة صاعدة";
            else if (size === 'medium') selectedCompanyLabel = "مستشفى خاص / نقابة";
            else selectedCompanyLabel = "مؤسسة كبرى / قطاع عام";

            document.querySelectorAll('.est-size-btn').forEach(btn => {
                btn.classList.remove('active', 'border-gold-500', 'bg-gold-50/50', 'dark:bg-gold-950/20', 'text-gold-600', 'dark:text-gold-400');
                btn.classList.add('border-primary-300', 'dark:border-primary-700', 'bg-white', 'dark:bg-primary-950', 'text-slate-600', 'dark:text-slate-300');
            });
            element.classList.remove('border-primary-300', 'dark:border-primary-700', 'bg-white', 'dark:bg-primary-950', 'text-slate-600', 'dark:text-slate-300');
            element.classList.add('active', 'border-gold-500', 'bg-gold-50/50', 'dark:bg-gold-950/20', 'text-gold-600', 'dark:text-gold-400');
            calculateCost();
        }

        function calculateCost() {
            const selectEl = document.getElementById('estService');
            const baseRate = parseInt(selectEl.options[selectEl.selectedIndex].getAttribute('data-rate'));
            const hours = parseInt(document.getElementById('estHours').value);
            const isUrgent = document.getElementById('estUrgent').checked;

            let subtotal = baseRate * hours * selectedCompanyMultiplier;
            let urgentFee = isUrgent ? (subtotal * 0.25) : 0;
            const total = subtotal + urgentFee;

            document.getElementById('estBaseRate').textContent = `$${baseRate}/ساعة`;
            document.getElementById('estSizeMultiplier').textContent = `${selectedCompanyMultiplier}x (${selectedCompanyLabel})`;
            document.getElementById('estUrgentLabel').textContent = isUrgent ? `+$${urgentFee.toFixed(0)} (25%)` : 'لا يوجد';
            document.getElementById('estTotalCost').textContent = `$${total.toLocaleString('en-US', {maximumFractionDigits: 0})}`;
        }

        function bookCalculatedConsultation() {
            const serviceName = document.getElementById('estService').options[document.getElementById('estService').selectedIndex].text;
            const hours = document.getElementById('estHours').value;
            const total = document.getElementById('estTotalCost').textContent;

            const textarea = document.querySelector('#bookingForm textarea');
            textarea.value = `أود طلب حجز موعد استشاري للخدمة السيادية: [${serviceName}] بنطاق مؤسسة: [${selectedCompanyLabel}] لعدد ساعات تقديرية: [${hours} ساعة]. الموازنة بالحاسبة هي: [${total}].`;
            
            document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
            showNotificationModal("تكامل ميزانية الحاسبة", "تم نقل وربط تفاصيل تقدير الحساب بنجاح لنموذج الحجز والمقابلة أدناه. يرجى ملء بيانات تواصلك لتأكيد الموعد مجاناً.");
        }

        function showNotificationModal(title, msg) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalMessage').textContent = msg;
            const modal = document.getElementById('notificationModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeNotificationModal() {
            const modal = document.getElementById('notificationModal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }

        function handleFormSubmit(e) {
            e.preventDefault();
            showNotificationModal("تم استلام الملف بنجاح!", "نشكرك لثقتك بمكتب المستشار صلاح حسن في العراق. تم تسجيل طلبك وجاري فحص وضع مؤسستك، وسيتصل بك منسق المكتب لتأكيد موعد المقابلة الاستكشافية الأولى مجاناً.");
            e.target.reset();
        }

        function handleNewsletterSubmit(e) {
            e.preventDefault();
            showNotificationModal("تم الاشتراك بنجاح سيادي!", "أهلاً بك بالقائمة البريدية الخاصة بالمكتب الاستشاري. سنرسل لك النشرات والأطروحات الجراحية الدورية فور صدورها.");
            e.target.reset();
        }

        // Simulating the AI Twin locally to avoid runtime API configuration breakage
        function handleChatSubmit(e) {
            e.preventDefault();
            const inputEl = document.getElementById('chatInput');
            const query = inputEl.value.trim();
            if (!query) return;

            inputEl.value = '';
            appendChatMessage(query, 'user');

            const placeholderId = appendChatMessage('قيد مراجعة ثغرات البنية التحتية لتوليد النصيحة...', 'bot-loading');

            setTimeout(() => {
                removeMessageElement(placeholderId);
                let reply = "بصفتي التوأم الرقمي للمستشار صلاح حسن، أرى أن ملفك يتطلب تدخلاً هندسياً دقيقاً. في بيئتنا الرقمية داخل العراق، تعاني الكثير من المنشآت الطبية والمؤسسات من انفصال كامل للسلطات الفنية، مما يجعل أصولها رهينة لشركات طرف ثالث خارجية وتتعثر اتصالاتها. ننصحك باستخدام حاسبة التكلفة المتاحة أو ملء نموذج الجلسة بالأسفل، ليقوم المستشار صلاح بجدولة مقابلة حقيقية وفحص أصولك سيادياً وإيقاف النزيف الرقمي تماماً.";
                appendChatMessage(reply, 'bot');
            }, 1500);
        }

        function appendChatMessage(text, sender) {
            const container = document.getElementById('chatMessages');
            const msgId = 'msg-' + Date.now();
            const wrapper = document.createElement('div');
            wrapper.id = msgId;
            wrapper.className = 'flex items-start gap-3 max-w-[85%] ' + (sender === 'user' ? 'mr-auto flex-row-reverse' : 'ml-auto');

            let avatar = sender === 'user' ? 
                `<div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-800 dark:text-white flex items-center justify-center shrink-0"><i class="fa-solid fa-user text-sm"></i></div>` :
                `<div class="w-8 h-8 rounded-full bg-gold-600 text-white flex items-center justify-center shrink-0"><i class="fa-solid fa-user-tie text-sm"></i></div>`;

            let bubbleClass = sender === 'user' ? 
                `bg-gold-500 text-white rounded-2xl rounded-tl-none p-4 shadow-sm border border-gold-600` :
                (sender === 'bot-loading' ? `bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border border-primary-200 dark:border-primary-800 shadow-sm text-slate-400 italic animate-pulse` : `bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border border-primary-200 dark:border-primary-800 shadow-sm text-slate-800 dark:text-slate-100`);

            wrapper.innerHTML = `
                ${avatar}
                <div class="${bubbleClass}">
                    <p class="text-sm leading-relaxed">${text}</p>
                    <span class="block text-[10px] text-slate-400 mt-2 text-left">الآن</span>
                </div>
            `;
            container.appendChild(wrapper);
            container.scrollTop = container.scrollHeight;
            return msgId;
        }

        function removeMessageElement(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        function clearChat() {
            const container = document.getElementById('chatMessages');
            container.innerHTML = `
                <div class="flex items-start gap-3 max-w-[85%]">
                    <div class="w-8 h-8 rounded-full bg-gold-600 text-white flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-user-tie text-sm"></i>
                    </div>
                    <div class="bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border border-primary-200 dark:border-primary-800 shadow-sm">
                        <p class="text-sm leading-relaxed text-slate-800 dark:text-slate-100">
                            تم تصفية سجل المحادثة بنجاح بطلبك. تفضل بطرح التحدي التنظيمي أو التقني اللّي تواجهه مؤسستك هسة لندرس آلية إنقاذه وتملكه سيادياً.
                        </p>
                        <span class="block text-[10px] text-slate-400 mt-2 text-left">الآن</span>
                    </div>
                </div>
            `;
        }
    </script>
</body>
</html>
