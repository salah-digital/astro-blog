        function renderCmsLists() {
            const sl = document.getElementById('cmsServicesList'); sl.innerHTML='';
            siteData.services.forEach(s => { sl.innerHTML += `<div class="flex justify-between items-center bg-white p-2 border rounded text-xs"><span>${s.title}</span><button onclick="delSvc('${s.id}')" class="text-red-500"><i class="fa-solid fa-trash"></i></button></div>`;});
            const al = document.getElementById('cmsArticlesList'); al.innerHTML='';
            siteData.articles.forEach(a => { al.innerHTML += `<div class="flex justify-between items-center bg-white p-2 border rounded text-xs"><span class="truncate w-3/4">${a.title}</span><button onclick="delArt('${a.id}')" class="text-red-500"><i class="fa-solid fa-trash"></i></button></div>`;});
            const tl = document.getElementById('cmsTestimonialsList'); tl.innerHTML='';
            siteData.testimonials.forEach(t => { tl.innerHTML += `<div class="flex justify-between items-center bg-white p-2 border rounded text-xs"><span>${t.name}</span><button onclick="delTest('${t.id}')" class="text-red-500"><i class="fa-solid fa-trash"></i></button></div>`;});
        }

        function delSvc(id) { siteData.services = siteData.services.filter(x => x.id !== id); renderCmsLists(); }
        function delArt(id) { siteData.articles = siteData.articles.filter(x => x.id !== id); renderCmsLists(); }
        function delTest(id) { siteData.testimonials = siteData.testimonials.filter(x => x.id !== id); renderCmsLists(); }

        function addServiceFromCms() {
            const title = document.getElementById('addSvcTitle').value;
            const icon = document.getElementById('addSvcIcon').value || 'fa-solid fa-star';
            const desc = document.getElementById('addSvcDesc').value;
            if(title && desc) { siteData.services.push({id: 'svc-'+Date.now(), title, icon, description: desc}); renderCmsLists(); }
        }
        function addArticleFromCms() {
            const title = document.getElementById('addArtTitle').value;
            const category = document.getElementById('addArtCategory').value || 'عام';
            const imgUrl = document.getElementById('addArtImgUrl').value || 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=600';
            const summary = document.getElementById('addArtSummary').value;
            const content = document.getElementById('addArtContent').value;
            const date = document.getElementById('addArtDate').value || 'الآن';
            if(title && content) { siteData.articles.unshift({id: 'art-'+Date.now(), title, category, date, imgUrl, summary, content}); renderCmsLists(); }
        }
        function addTestimonialFromCms() {
            const name = document.getElementById('addTestName').value;
            const title = document.getElementById('addTestTitle').value;
            const text = document.getElementById('addTestText').value;
            const stars = document.getElementById('addTestStars').value || "5";
            if(name && text) { siteData.testimonials.push({id: 'tst-'+Date.now(), name, title, text, stars}); renderCmsLists(); }
        }

