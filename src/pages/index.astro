        // Article Read Modal actions
        function readFullArticle(id) {
            const art = siteData.articles.find(a => a.id === id);
            if (!art) return;

            document.getElementById('readArtCategory').textContent = art.category;
            document.getElementById('readArtTitle').textContent = art.title;
            document.getElementById('readArtDate').innerHTML = `<i class="fa-regular fa-calendar ml-1.5"></i>تاريخ النشر: ${art.date}`;
            document.getElementById('readArtImage').src = art.imgUrl;
            document.getElementById('readArtContent').textContent = art.content;

            const modal = document.getElementById('articleReadModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeArticleReadModal() {
            const modal = document.getElementById('articleReadModal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }

        // Handle Admin Button Click (Protected Login / CMS Opening)
        function handleAdminPanelClick() {
            if (isAdminLoggedIn) {
                toggleAdminPanel();
            } else {
                openAdminLoginModal();
            }
        }

        function openAdminLoginModal() {
            const modal = document.getElementById('adminLoginModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeAdminLoginModal() {
            const modal = document.getElementById('adminLoginModal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }

        // Verify Admin Credentials (Strictly salahhibrahim131@gmail.com)
        function handleAdminLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value.trim();
            const pass = document.getElementById('loginPassword').value;

            if (email === ADMIN_EMAIL && pass === siteData.contact.password) {
                isAdminLoggedIn = true;
                closeAdminLoginModal();
                toggleAdminPanel();
                showNotificationModal("نجاح تسجيل الدخول!", "أهلاً بك المستشار صلاح حسن إبراهيم، يمكنك الآن حيازة وتعديل ونشر كافة ممتلكات موقعك الإلكتروني عبر لوحة الإدارة الفورية.");
                // Reset form fields
                e.target.reset();
            } else {
                showNotificationModal("فشل التحقق!", "عذراً، البريد الإلكتروني أو كلمة المرور غير صحيحة. يرجى إعادة التحقق لتأمين النظام.");
            }
        }

        // Custom Modal Confirmation Actions (Replacing window.confirm)
        function triggerRestoreDefaultConfirm() {
            showConfirmModal(
                "هل ترغب بإعادة التعيين للأصل؟", 
                "سيتم حذف جميع تعديلاتك الحالية، صورك المضافة، ومقالاتك المحدثة والرجوع لتصميم وهيكل البناء الأساسي للموقع الافتراضي.",
                function() {
                    localStorage.removeItem('salah_office_cms_state');
                    isAdminLoggedIn = false;
                    loadSiteState();
                    toggleAdminPanel();
                    closeConfirmModal();
                    showNotificationModal("تمت إعادة التعيين", "تم استرجاع النسخة الأساسية والأصلية بنجاح لمكتب المستشار صلاح حسن.");
                }
            );
        }

        function showConfirmModal(title, msg, onConfirmCallback) {
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = msg;
            
