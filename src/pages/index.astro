                <a href="#about" class="hover:text-gold-600 dark:hover:text-gold-400 font-semibold transition-colors">عن المستشار</a>
                <a href="#services" class="hover:text-gold-600 dark:hover:text-gold-400 font-semibold transition-colors">خدماتنا</a>
                <a href="#articles" class="hover:text-gold-600 dark:hover:text-gold-400 font-semibold transition-colors">المقالات والدراسات</a>
                <a href="#assessment" class="hover:text-gold-600 dark:hover:text-gold-400 font-semibold transition-colors flex items-center gap-1.5">
