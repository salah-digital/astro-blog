// بروتوكول الشحن السيادي المباشر من لوحة التحكم إلى مستودع جيتهاب
async function pushChangesToGitHub(updatedData) {
    const OWNER = "salah-digital"; // اسم حسابك في جيتهاب
    const REPO = "astro-blog";     // اسم المستودع
    const PATH = "src/config.ts";  // الملف المستهدف بالتحديث
    const TOKEN = "YOUR_GITHUB_PERSONAL_TOKEN"; // رمز الوصول الخاص بك المولد من جيتهاب

    const apiUrl = `https://api.github.com/repos/${OWNER}/${REPO}/contents/${PATH}`;

    try {
        // 1. جلب معرف الملف الحالي لضمان عدم حدوث تعارض برمي
        const fileResponse = await fetch(apiUrl, {
            headers: { "Authorization": `token ${TOKEN}` }
        });
        const fileData = await fileResponse.json();
        const currentSha = fileData.sha;

        // 2. صياغة محتوى ملف الإعدادات الجديد بالكامل بناءً على تعديلات اللوحة
        const fileContent = `export const SITE_METADATA = ${JSON.stringify(updatedData, null, 2)};`;
        
        // 3. تشفير المحتوى بلغة النقل العالمية (Base64)
        const encodedContent = btoa(unescape(encodeURIComponent(fileContent)));

        // 4. دفع التحديث مباشرة إلى السيرفر عبر واجهة برمجة التطبيقات
        const updateResponse = await fetch(apiUrl, {
            method: "PUT",
            headers: {
                "Authorization": `token ${TOKEN}`,
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                message: "تحديث سيادي لنصوص الواجهة من لوحة تحكم الموقع الداخلية",
                content: encodedContent,
                sha: currentSha
            })
        });

        if (updateResponse.ok) {
            showNotificationModal("نجاح التوطين السحابي", "تم تحديث مستودع الكود بنجاح مية بالمية، وجارِ إعادة بناء الموقع لايف عبر كلاود فلير خلال دقيقة واحدة.");
        } else {
            throw new Error("فشل في دفع التحديث للسيرفر الرئيسي");
        }
    } catch (error) {
        showNotificationModal("خطأ في الاتصال السيادي", "تعذر إرسال البيانات مباشرة. تأكد من صلاحية رمز الوصول الشخصي الخاص بجيتهاب.");
    }
}
