    <section id="assessment" class="py-20 bg-white dark:bg-primary-900/40">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-2xl mx-auto mb-12 space-y-3">
                <span class="text-sm font-bold text-gold-600 dark:text-gold-400 block"><i class="fa-solid fa-gauge-high ml-1"></i>تقييم فوري</span>
                <h2 class="text-3xl font-extrabold text-primary-950 dark:text-white">مقياس النضج للسيادة الرقمية</h2>
            </div>
            <div class="bg-primary-50 dark:bg-primary-900 border border-primary-200 dark:border-primary-800 rounded-3xl p-6 sm:p-10 shadow-xl relative overflow-hidden">
                <div class="w-full bg-primary-200 dark:bg-primary-800 h-2 rounded-full mb-8"><div id="quizProgress" class="bg-gradient-to-r from-gold-500 to-amber-500 h-2 rounded-full transition-all duration-300" style="width: 20%;"></div></div>
                <div id="quizWindow">
                    <div class="quiz-step active space-y-6" data-step="1">
                        <span class="text-gold-600 dark:text-gold-400 text-sm font-bold">السؤال 1 من 5</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-primary-950 dark:text-white">هل تمتلك مؤسستك تحكماً برمجياً مستقلاً 100% في موقعها وتطبيقاتها؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(1, 3)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نعم، نمتلك الشيفرة المصدرية والاستضافة بالكامل.</button>
                            <button onclick="nextQuizStep(1, 2)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نمتلك الموقع ولكننا نعتمد على منصات جاهزة ومغلقة.</button>
                            <button onclick="nextQuizStep(1, 0)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">لا، نعتمد على شبكات التواصل الاجتماعي فقط للتواجد.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="2">
                        <span class="text-gold-600 dark:text-gold-400 text-sm font-bold">السؤال 2 من 5</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-primary-950 dark:text-white">كيف يتم إدارة السمعة المؤسسية الرقمية ومعالجة الشكاوى؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(2, 3)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">بشكل مؤسسي عبر غرف عمليات وتحليل دائم للبيانات.</button>
                            <button onclick="nextQuizStep(2, 1)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">بشكل عشوائي عند حدوث الأزمات فقط.</button>
                            <button onclick="nextQuizStep(2, 0)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">لا يوجد فريق أو إجراءات مخصصة لإدارة السمعة.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="3">
                        <span class="text-gold-600 dark:text-gold-400 text-sm font-bold">السؤال 3 من 5</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-primary-950 dark:text-white">هل تم تطبيق فصل السلطات التقنية بين الإدارة ومزودي الخدمة؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(3, 3)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">نعم، الإدارة العليا تملك الحوكمة والتحكم السيادي.</button>
                            <button onclick="nextQuizStep(3, 1)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">جزئياً، هناك تداخل بالصلاحيات مع الجهات المنفذة.</button>
                            <button onclick="nextQuizStep(3, 0)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">لا، المبرمجون والشركات الخارجية يملكون التحكم الكامل.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="4">
                        <span class="text-gold-600 dark:text-gold-400 text-sm font-bold">السؤال 4 من 5</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-primary-950 dark:text-white">هل تقومون بتحسين وتكتيل مواقعكم على الخرائط (Local SEO)؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(4, 3)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">نعم، ندير الأصول المكانية باحتراف لجلب الاتصالات.</button>
                            <button onclick="nextQuizStep(4, 1)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">لدينا مواقع على الخرائط ولكنها مهملة وغير محدثة.</button>
                            <button onclick="nextQuizStep(4, 0)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">لا نهتم بهذا الجانب مطلقاً.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="5">
                        <span class="text-gold-600 dark:text-gold-400 text-sm font-bold">السؤال 5 من 5</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-primary-950 dark:text-white">هل بيانات المؤسسة والعملاء مؤمنة داخل أنظمة حوكمة سحابية موثوقة؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(5, 3)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">نعم، نطبق أعلى معايير الحماية والأمان السيبراني.</button>
                            <button onclick="nextQuizStep(5, 1)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">نستخدم حماية أساسية وتقليدية غير متقدمة.</button>
                            <button onclick="nextQuizStep(5, 0)" class="w-full text-right p-4 rounded-xl border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 font-semibold">لا يوجد تأمين حقيقي والبيانات موزعة عشوائياً.</button>
                        </div>
                    </div>
