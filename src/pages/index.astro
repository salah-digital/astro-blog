        // Add service handler in CMS
        function addServiceFromCms() {
            const title = document.getElementById('addSvcTitle').value.trim();
            const icon = document.getElementById('addSvcIcon').value.trim() || 'fa-solid fa-shield';
            const desc = document.getElementById('addSvcDesc').value.trim();

            if (!title || !desc) {
                showNotificationModal("خطأ إدخال", "يرجى تعبئة اسم الخدمة الاستشارية والوصف أولاً لتتمكن من إضافتها.");
                return;
            }

            const newService = {
                id: 'svc-' + Date.now(),
                title: title,
                icon: icon,
                description: desc
            };

            siteData.services.push(newService);
            renderCmsServicesList();

            // Clear inputs
            document.getElementById('addSvcTitle').value = '';
            document.getElementById('addSvcIcon').value = '';
            document.getElementById('addSvcDesc').value = '';

            showNotificationModal("إضافة خدمة", "تم تجهيز الخدمة الجديدة. يرجى النقر على زر 'حفظ التغييرات الآن' لتثبيت الإضافة بنجاح.");
        }

