    <!-- About Section -->
    <section id="about" class="py-20 bg-white dark:bg-primary-900/30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <!-- Left Visual Image of About (Managed by CMS) -->
