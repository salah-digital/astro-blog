                    <div><span class="block text-2xl sm:text-3xl font-extrabold text-gold-600 dark:text-gold-400">100%</span><span class="text-xs sm:text-sm text-slate-500 dark:text-slate-400">توطين للأصول</span></div>
                    <div><span class="block text-2xl sm:text-3xl font-extrabold text-gold-600 dark:text-gold-400">Level 10</span><span class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 font-medium">Local Guide</span></div>
                    <div><span class="block text-2xl sm:text-3xl font-extrabold text-gold-600 dark:text-gold-400">0%</span><span class="text-xs sm:text-sm text-slate-500 dark:text-slate-400">نزيف تقني</span></div>
                </div>
