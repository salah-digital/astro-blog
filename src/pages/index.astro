                address: "بغداد، جمهورية العراق",
                email: "consultant.salahhasan@gmail.com",
                phone: "+9647706556772",
                whatsapp: "9647706556772"
            },
            services: [
                { id: "svc-1", title: "السيادة الرقمية وتوطين البيانات", icon: "fa-solid fa-code", description: "تأسيس بنية برمجية مستقلة وحماية الأصول من احتكار خوادم الطرف الثالث." },
                { id: "svc-2", title: "التحسين الجراحي (Surgical SEO)", icon: "fa-solid fa-map-location-dot", description: "إدارة الهيمنة الجغرافية والتكتل المكاني للشركات لجلب اتصالات فائقة الجودة." },
                { id: "svc-3", title: "إدارة السمعة وفصل السلطات", icon: "fa-solid fa-shield-halved", description: "بناء سياسات الحماية للصورة الذهنية وتأمين الصلاحيات التقنية للمستشفيات والمؤسسات." }
            ],
            testimonials: [
                { id: "test-1", name: "د. مدير طبي", title: "مستشفى أهلي ببغداد", stars: "5", text: "تدخل المستشار أوقف النزيف التقني وأعاد لنا السيادة على بيانات المرضى وأنظمة الحجوزات بالكامل." }
            ]
        };

        let siteData = {};
        let currentQuizStep = 1;
        let quizScore = 0;
        let selectedCompanyMultiplier = 1.0;

        window.onload = function() {
            if(!localStorage.getItem('salah_baghdad_v5')) {
                localStorage.removeItem('salah_office_cms_state');
                localStorage.setItem('salah_baghdad_v5', 'true');
            }
            loadSiteState();
            document.getElementById('currentYear').textContent = new Date().getFullYear();
            calculateCost();
            if (localStorage.getItem('theme') === 'dark') { toggleTheme(); }
        };

        function loadSiteState() {
            const savedState = localStorage.getItem('salah_office_cms_state');
            siteData = savedState ? JSON.parse(savedState) : JSON.parse(JSON.stringify(DEFAULT_SITE_DATA));
            renderAllCmsElements();
        }

        function renderAllCmsElements() {
            document.getElementById('headerLogoMain').textContent = siteData.general.logoMain;
            document.getElementById('headerLogoSub').textContent = siteData.general.logoSub;
            document.getElementById('welcomeMarquee').innerHTML = `<span>${siteData.general.marqueeText}</span><span> • </span><span>${siteData.general.marqueeText}</span>`;
            document.getElementById('heroBadge').textContent = siteData.general.heroBadge;
            document.getElementById('heroTitle').innerHTML = siteData.general.heroTitle;
            document.getElementById('heroDescription').textContent = siteData.general.heroDescription;
            document.getElementById('heroCardName').textContent = siteData.general.heroCardName;
            document.getElementById('heroCardTitle').textContent = siteData.general.heroCardTitle;
            document.getElementById('heroQuote').textContent = siteData.general.heroQuote;
            document.getElementById('aboutSubtitle').textContent = siteData.general.aboutSubtitle;
            document.getElementById('aboutMainTitle').textContent = siteData.general.aboutMainTitle;
            document.getElementById('aboutMainText').textContent = siteData.general.aboutMainText;
            document.getElementById('contactAddress').textContent = siteData.contact.address;
            document.getElementById('contactEmail').textContent = siteData.contact.email;
            document.getElementById('contactPhone').textContent = siteData.contact.phone;

            const whatsappUrl = `https://wa.me/${siteData.contact.whatsapp}?text=${encodeURIComponent('مرحباً المستشار صلاح حسن، أطلب تفعيل بروتوكول الإنقاذ الرقمي لمؤسستي.')}`;
            document.getElementById('whatsappFloat').href = whatsappUrl;
            document.getElementById('contactWhatsappLink').href = whatsappUrl;

            // Render Services
            const servicesGrid = document.getElementById('dynamicServicesGrid');
            const bookingSelect = document.getElementById('bookingServiceSelect');
            if(servicesGrid) servicesGrid.innerHTML = '';
            if(bookingSelect) bookingSelect.innerHTML = '';
            
            siteData.services.forEach(svc => {
                if(servicesGrid) servicesGrid.innerHTML += `<div class="bg-white dark:bg-primary-900 p-8 rounded-2xl shadow-xl border border-primary-100 dark:border-primary-800"><div class="w-14 h-14 bg-gold-100 text-gold-600 flex items-center justify-center rounded-xl mb-4"><i class="${svc.icon} text-2xl"></i></div><h3 class="text-xl font-bold mb-2">${svc.title}</h3><p class="text-sm text-slate-500">${svc.description}</p></div>`;
                if(bookingSelect) bookingSelect.innerHTML += `<option value="${svc.title}">${svc.title}</option>`;
            });

            // Render Testimonials
            const testGrid = document.getElementById('dynamicTestimonialsGrid');
            if(testGrid) {
                testGrid.innerHTML = '';
                siteData.testimonials.forEach(test => {
                    let stars = '<i class="fa-solid fa-star"></i>'.repeat(parseInt(test.stars));
                    testGrid.innerHTML += `<div class="bg-white dark:bg-primary-900 p-8 rounded-2xl shadow-xl"><div class="text-gold-500 flex gap-1">${stars}</div><p class="text-sm my-4 italic">"${test.text}"</p><div class="flex items-center gap-3 border-t pt-4"><div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center font-bold text-xs">${test.name.substring(0,2)}</div><div><span class="block font-bold">${test.name}</span><span class="text-xs text-slate-400">${test.title}</span></div></div></div>`;
                });
            }

            // Fill CMS Inputs
            document.getElementById('inpLogoMain').value = siteData.general.logoMain;
            document.getElementById('inpLogoSub').value = siteData.general.logoSub;
            document.getElementById('inpMarqueeText').value = siteData.general.marqueeText;
            document.getElementById('inpHeroBadge').value = siteData.general.heroBadge;
            document.getElementById('inpHeroTitle').value = siteData.general.heroTitle;
            document.getElementById('inpHeroDesc').value = siteData.general.heroDescription;
            document.getElementById('inpHeroCardName').value = siteData.general.heroCardName;
            document.getElementById('inpHeroCardTitle').value = siteData.general.heroCardTitle;
            document.getElementById('inpHeroQuote').value = siteData.general.heroQuote;
            document.getElementById('inpAboutSubtitle').value = siteData.general.aboutSubtitle;
            document.getElementById('inpAboutTitle').value = siteData.general.aboutMainTitle;
            document.getElementById('inpAboutText').value = siteData.general.aboutMainText;
            document.getElementById('inpContactAddress').value = siteData.contact.address;
            document.getElementById('inpContactEmail').value = siteData.contact.email;
            document.getElementById('inpContactPhone').value = siteData.contact.phone;
            document.getElementById('inpContactWhatsapp').value = siteData.contact.whatsapp;
        }

        // CMS Logic
        function toggleAdminPanel() {
            const panel = document.getElementById('adminPanel');
            panel.classList.toggle('hidden');
            panel.classList.toggle('flex');
        }
        function switchAdminTab(tabName) {
            document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('border-gold-500', 'text-gold-600'));
            document.querySelectorAll('.admin-sect').forEach(s => s.classList.add('hidden'));
            document.getElementById('tab-' + tabName).classList.add('border-gold-500', 'text-gold-600');
            document.getElementById('admin-sect-' + tabName).classList.remove('hidden');
        }
        function saveAndApplyCmsChanges() {
            siteData.general.logoMain = document.getElementById('inpLogoMain').value;
            siteData.general.logoSub = document.getElementById('inpLogoSub').value;
            siteData.general.marqueeText = document.getElementById('inpMarqueeText').value;
            siteData.general.heroBadge = document.getElementById('inpHeroBadge').value;
            siteData.general.heroTitle = document.getElementById('inpHeroTitle').value;
            siteData.general.heroDescription = document.getElementById('inpHeroDesc').value;
            siteData.general.heroCardName = document.getElementById('inpHeroCardName').value;
            siteData.general.heroCardTitle = document.getElementById('inpHeroCardTitle').value;
            siteData.general.heroQuote = document.getElementById('inpHeroQuote').value;
            siteData.general.aboutSubtitle = document.getElementById('inpAboutSubtitle').value;
            siteData.general.aboutMainTitle = document.getElementById('inpAboutTitle').value;
            siteData.general.aboutMainText = document.getElementById('inpAboutText').value;
            siteData.contact.address = document.getElementById('inpContactAddress').value;
            siteData.contact.email = document.getElementById('inpContactEmail').value;
            siteData.contact.phone = document.getElementById('inpContactPhone').value;
            siteData.contact.whatsapp = document.getElementById('inpContactWhatsapp').value;

            localStorage.setItem('salah_office_cms_state', JSON.stringify(siteData));
            renderAllCmsElements();
            toggleAdminPanel();
            showNotificationModal("تم الحفظ!", "البيانات السيادية تم تحديثها بنجاح في الواجهة.");
        }
        function restoreDefaultConfig() {
            if(confirm("هل تريد استعادة بيانات بغداد الأصلية؟")) {
                localStorage.removeItem('salah_office_cms_state');
                loadSiteState();
                toggleAdminPanel();
            }
        }

        // Utils
        function toggleMobileMenu() { document.getElementById('mobileMenu').classList.toggle('hidden'); }
        function toggleTheme() {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        }
        function showNotificationModal(title, msg) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalMessage').textContent = msg;
            document.getElementById('notificationModal').classList.replace('hidden', 'flex');
        }
        function closeNotificationModal() { document.getElementById('notificationModal').classList.replace('flex', 'hidden'); }
        function handleFormSubmit(e) { e.preventDefault(); showNotificationModal("تم", "سيتم التواصل من قبل المكتب السيادي قريباً."); e.target.reset(); }

        // Quiz Logic
        function nextQuizStep(step, points) {
            quizScore += points;
            document.querySelector(`.quiz-step[data-step="${step}"]`).classList.add('hidden');
            if(step < 5) {
                document.querySelector(`.quiz-step[data-step="${step+1}"]`).classList.remove('hidden');
                document.getElementById('quizProgress').style.width = ((step+1)/5)*100 + '%';
            } else {
                document.getElementById('quizResult').classList.remove('hidden');
                document.getElementById('quizScoreDisplay').textContent = quizScore;
                if(quizScore > 10) { document.getElementById('resultLevelTitle').textContent = "متقدم - نضج عالي"; document.getElementById('resultAdvice').textContent = "حافظ على السيادة الجغرافية وتطوير الخرائط."; }
                else { document.getElementById('resultLevelTitle').textContent = "مستوى حرج"; document.getElementById('resultAdvice').textContent = "تحتاج لبروتوكول إنقاذ رقمي عاجل وفصل سلطات."; }
            }
        }
        function resetQuiz() { quizScore = 0; document.getElementById('quizResult').classList.add('hidden'); document.getElementById('quizProgress').style.width='20%'; document.querySelectorAll('.quiz-step').forEach(s => s.classList.add('hidden')); document.querySelector('.quiz-step[data-step="1"]').classList.remove('hidden'); }

        // Estimator
        function setEstCompanySize(size, multiplier, el) { selectedCompanyMultiplier = multiplier; document.querySelectorAll('.est-size-btn').forEach(b => b.classList.remove('active', 'border-gold-500')); el.classList.add('active', 'border-gold-500'); calculateCost(); }
        function updateHoursRange(val) { document.getElementById('estHoursDisplay').textContent = val; calculateCost(); }
        function calculateCost() {
            let el = document.getElementById('estService');
            let rate = parseInt(el.options[el.selectedIndex].getAttribute('data-rate'));
            let hours = parseInt(document.getElementById('estHours').value);
            let urg = document.getElementById('estUrgent').checked ? 1.25 : 1;
            let total = (rate * hours * selectedCompanyMultiplier * urg).toFixed(0);
            document.getElementById('estBaseRate').textContent = `$${rate}`;
            document.getElementById('estSizeMultiplier').textContent = `x${selectedCompanyMultiplier}`;
            document.getElementById('estUrgentLabel').textContent = urg > 1 ? '+25%' : '0';
            document.getElementById('estTotalCost').textContent = `$${total}`;
        }
        function bookCalculatedConsultation() { document.getElementById('contact').scrollIntoView(); }

        // Chat
        function handleChatSubmit(e) {
            e.preventDefault();
            let inp = document.getElementById('chatInput');
            if(!inp.value) return;
            document.getElementById('chatMessages').innerHTML += `<div class="flex items-start gap-3 max-w-[85%] mr-auto flex-row-reverse"><div class="w-8 h-8 bg-slate-200 flex items-center justify-center rounded-full"><i class="fa-solid fa-user"></i></div><div class="bg-gold-500 text-white p-4 rounded-2xl rounded-tl-none"><p class="text-sm">${inp.value}</p></div></div>`;
            inp.value = '';
            setTimeout(() => {
                document.getElementById('chatMessages').innerHTML += `<div class="flex items-start gap-3 max-w-[85%]"><div class="w-8 h-8 bg-gold-600 text-white flex items-center justify-center rounded-full"><i class="fa-solid fa-user-tie text-sm"></i></div><div class="bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border"><p class="text-sm">لإتمام الإجابة التقنية بدقة ولأنني التوأم الافتراضي، يرجى تفعيل مفتاح Gemini أو الضغط على زر الواتساب أسفل الشاشة لحجز جلسة مباشرة مع المستشار صلاح حسن في بغداد.</p></div></div>`;
                document.getElementById('chatMessages').scrollTop = document.getElementById('chatMessages').scrollHeight;
            }, 1000);
        }
        function clearChat() { document.getElementById('chatMessages').innerHTML = '<div class="flex items-start gap-3 max-w-[85%]"><div class="w-8 h-8 bg-gold-600 text-white flex items-center justify-center rounded-full"><i class="fa-solid fa-user-tie text-sm"></i></div><div class="bg-white dark:bg-primary-950 p-4 rounded-2xl rounded-tr-none border"><p class="text-sm">تم تصفير الذاكرة. كيف أساعدك؟</p></div></div>'; }
    </script>
</body>
</html>
