                ghostClickCount = 0;
                if(isAdminLoggedIn) { toggleAdminPanel(); } else { document.getElementById('adminLoginModal').classList.replace('hidden', 'flex'); }
            }
        }

        function handleAdminLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value.trim();
