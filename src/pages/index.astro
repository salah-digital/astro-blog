        // Add service handler in CMS
        function addServiceFromCms() {
            const title = document.getElementById('addSvcTitle').value.trim();
            const icon = document.getElementById('addSvcIcon').value.trim() || 'fa-solid fa-shield';
            const desc = document.getElementById('addSvcDesc').value.trim();

            if (!title || !desc) {
                showNotificationModal("خطأ إدخال", "يرجى تعبئة اسم الخدمة الاستشارية والوصف أولاً لتتمكن من إضافتها.");
                return;
            }

            const newService = {
                id: 'svc-' + Date.now(),
                title: title,
                icon: icon,
                description: desc
            };

            siteData.services.push(newService);
            renderCmsServicesList();

            // Clear inputs
            document.getElementById('addSvcTitle').value = '';
            document.getElementById('addSvcIcon').value = '';
            document.getElementById('addSvcDesc').value = '';

            showNotificationModal("إضافة مؤقتة ناجحة", "تمت إضافة الخدمة الجديدة لقائمتك. يرجى الضغط على زر 'حفظ التغييرات الآن' أسفل لوحة التحكم لتطبيقها على الموقع بالكامل.");
        }

        // Delete service in CMS
        function deleteServiceFromCms(id) {
            siteData.services = siteData.services.filter(svc => svc.id !== id);
            renderCmsServicesList();
        }

        // Render Testimonials inside CMS manager list
        function renderCmsTestimonialsList() {
            const listContainer = document.getElementById('cmsTestimonialsList');
            if(!listContainer) return;
            listContainer.innerHTML = '';
            siteData.testimonials.forEach(test => {
                const item = document.createElement('div');
                item.className = "flex items-center justify-between p-3 bg-primary-100/50 dark:bg-primary-950/80 border dark:border-primary-800 rounded-lg text-xs";
                item.innerHTML = `
                    <div>
                        <span class="font-bold block">${test.name}</span>
                        <span class="text-[10px] text-slate-400 block">${test.title}</span>
                    </div>
                    <button onclick="deleteTestimonialFromCms('${test.id}')" class="text-red-500 hover:text-red-700 font-bold px-2 py-1"><i class="fa-solid fa-trash-can"></i></button>
                `;
                listContainer.appendChild(item);
            });
