        let ghostClickCount = 0;
        let ghostTimer;
        function secretAdminTrigger() {
            ghostClickCount++;
            clearTimeout(ghostTimer);
            ghostTimer = setTimeout(() => { ghostClickCount = 0; }, 1500); 
