        // Export data backup JSON
        function exportSiteBackup() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(siteData, null, 2));
            const downloadAnchor = document.createElement('a');
            downloadAnchor.setAttribute("href", dataStr);
            downloadAnchor.setAttribute("download", "salah_consultant_site_backup.json");
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            downloadAnchor.remove();
        }

        // Import data backup JSON
        function importSiteBackup() {
            const fileInput = document.getElementById('importJsonFileInput');
            const file = fileInput.files[0];
            if (!file) {
                showNotificationModal("لم يتم اختيار ملف", "يرجى تحديد ملف النسخة الاحتياطية بصيغة .json من جهازك أولاً.");
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const parsedData = JSON.parse(e.target.result);
                    // Minimal validation
                    if (parsedData.general && parsedData.services && parsedData.testimonials) {
                        siteData = parsedData;
                        localStorage.setItem('salah_office_cms_state', JSON.stringify(siteData));
                        renderAllCmsElements();
                        calculateCost();
                        toggleAdminPanel();
                        showNotificationModal("تم استيراد بنجاح", "تمت قراءة ملف JSON وتطبيق تصميم ومحتوى موقعك المخصص فورياً بنجاح تام.");
                    } else {
                        showNotificationModal("ملف غير صالح", "مضمون ملف JSON غير متوافق مع نظام إدارة الموقع المحدث.");
                    }
                } catch (err) {
                    showNotificationModal("فشل في القراءة", "لم نتمكن من تحليل وقراءة الملف. تأكد من أن الملف بصيغة JSON سليمة.");
                }
            };
            reader.readAsText(file);
        }

