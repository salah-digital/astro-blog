        // Add testimonial handler in CMS
        function addTestimonialFromCms() {
            const name = document.getElementById('addTestName').value.trim();
            const title = document.getElementById('addTestTitle').value.trim();
            const stars = document.getElementById('addTestStars').value;
            const text = document.getElementById('addTestText').value.trim();

            if (!name || !text) {
                showNotificationModal("خطأ إدخال", "يرجى ملء اسم العميل ورأيه لحفظ التوصية في الموقع.");
                return;
            }

            const newTest = {
                id: 'test-' + Date.now(),
                name: name,
                title: title || 'شريك نجاح',
                stars: stars,
                text: text
            };

            siteData.testimonials.push(newTest);
            renderCmsTestimonialsList();

            // Clear inputs
            document.getElementById('addTestName').value = '';
            document.getElementById('addTestTitle').value = '';
            document.getElementById('addTestText').value = '';

            showNotificationModal("تجهيز رأي العميل", "تمت إضافة شهادة العميل بنجاح. اضغط على زر 'حفظ التغييرات الآن' في الأسفل لتثبيت هذا الرأي في الواجهة الأمامية للموقع.");
        }

        // Delete testimonial in CMS
        function deleteTestimonialFromCms(id) {
            siteData.testimonials = siteData.testimonials.filter(test => test.id !== id);
            renderCmsTestimonialsList();
        }

