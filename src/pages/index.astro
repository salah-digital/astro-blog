                heroBadge: "بوابتك الريادية للسيادة الرقمية وإدارة السمعة",
                heroTitle: "نصنع المستقبل الرقمي لمؤسستك وأعمالك",
                heroDescription: "مكتب المستشار صلاح حسن إبراهيم يقدم باقة متكاملة من الاستشارات الاستراتيجية والحلول التقنية المبتكرة لتمكين الشركات من قيادة السوق وضمان السمعة المؤسسية المرموقة والسيادة الرقمية الكاملة.",
                heroCardName: "المستشار صلاح حسن إبراهيم",
                heroCardTitle: "خبير السيادة الرقمية وإدارة السمعة المؤسسية",
                heroQuote: "\"التحول الرقمي وإدارة السمعة والسيادة الرقمية ليست مجرد أدوات تقنية، بل هي حجر الزاوية لحماية ريادة المؤسسة وبناء ثقة مستدامة.\""
            },
            contact: {
                address: "العراق - بغداد",
                email: "consultant.salahhasan@gmail.com",
                phone: "+9647706556772",
                whatsapp: "9647706556772",
                password: "Salah@2026"
            },
            services: [
                { id: "svc-1", title: "السيادة الرقمية وحماية البيانات", icon: "fa-solid fa-shield-halved", description: "حوكمة البيانات الحساسة، تأمين البنية التحتية للمؤسسات والشركات، وتأسيس قواعد السيادة التقنية الكاملة المستقلة." },
                { id: "svc-2", title: "إدارة السمعة المؤسسية والأزمات", icon: "fa-solid fa-users-gear", description: "بناء وإدارة الهوية الرقمية للمؤسسات، تتبع انطباعات الجمهور، وحيازة استراتيجيات مبتكرة لإدارة السمعة وتخفيف وطأة الأزمات." }
            ],
            articles: [
                { id: "art-1", title: "السيادة الرقمية في بيئة الأعمال المعاصرة", category: "السيادة الرقمية", date: "1 يونيو 2026", imgUrl: "", summary: "دليل استراتيجي للمدراء والتنفيذيين حول سبل حيازة المؤسسة لاستقلالها التكنولوجي وحماية قواعد البيانات الكبرى.", content: "تعتبر السيادة الرقمية حجر الزاوية للمؤسسات التي تسعى لبناء نموذج عمل محصن ومستقل..." }
            ],
            testimonials: []
        };

        let siteData = {};
        let isAdminLoggedIn = false;

        // دالة الفحص السيادي الصارم للهوية لفتح بوابة المشرف بناءً على متصفح الإيميل المعتمد
        function checkIdentityAndFilterCms() {
            // جلب البريد الذي تم تسجيل الدخول به من متصفح إيميل العميل (الويب ميل أو الجلسة المحلية المقترنة)
            const activeSessionEmail = localStorage.getItem('active_webmail_session') || "";
            const adminButton = document.getElementById('adminCmsButton');
            
            // قفل أمني: زر بوابة المشرف مخفي تماماً عن الجميع، ويظهر لمالك هذا الإيميل حصراً
            if (activeSessionEmail.trim().toLowerCase() === ADMIN_EMAIL) {
                adminButton.classList.remove('hidden');
                adminButton.classList.add('inline-flex');
            } else {
                adminButton.classList.remove('inline-flex');
                adminButton.classList.add('hidden');
            }
        }

        window.onload = function() {
            // محاكاة اقتران متصفح الإيميل الخاص بالموقع (يتم حسم الهوية وتثبيت قفل مالك البريد هنا)
            if(!localStorage.getItem('active_webmail_session')) {
                localStorage.setItem('active_webmail_session', 'salahhibrahim131@gmail.com');
            }
            
            loadSiteState();
            document.getElementById('currentYear').textContent = new Date().getFullYear();
            checkIdentityAndFilterCms(); // تفعيل جدار حماية الهوية فوراً عند التحميل
        };

        function loadSiteState() {
            const savedState = localStorage.getItem('salah_office_cms_state');
            siteData = savedState ? JSON.parse(savedState) : JSON.parse(JSON.stringify(DEFAULT_SITE_DATA));
            renderAllCmsElements();
        }

        function renderAllCmsElements() {
            document.getElementById('headerLogoMain').textContent = siteData.general.logoMain;
            document.getElementById('headerLogoSub').textContent = siteData.general.logoSub;
            document.getElementById('welcomeMarquee').innerHTML = `<span>${siteData.general.marqueeText}</span><span>•</span><span>${siteData.general.marqueeText}</span>`;
            document.getElementById('heroBadge').textContent = siteData.general.heroBadge;
            document.getElementById('heroTitle').innerHTML = siteData.general.heroTitle;
            document.getElementById('heroDescription').textContent = siteData.general.heroDescription;
            document.getElementById('heroCardName').textContent = siteData.general.heroCardName;
            document.getElementById('heroCardTitle').textContent = siteData.general.heroCardTitle;
            document.getElementById('heroQuote').textContent = siteData.general.heroQuote;
            document.getElementById('contactAddress').textContent = siteData.contact.address;
            document.getElementById('contactEmail').textContent = siteData.contact.email;
            document.getElementById('contactPhone').textContent = siteData.contact.phone;

            const servicesGrid = document.getElementById('dynamicServicesGrid');
            const bookingSelect = document.getElementById('bookingServiceSelect');
            if(servicesGrid && bookingSelect) {
                servicesGrid.innerHTML = ''; bookingSelect.innerHTML = '';
                siteData.services.forEach(svc => {
                    servicesGrid.innerHTML += `<div class="bg-white dark:bg-primary-900 p-8 rounded-2xl shadow-xl border"><h3 class="text-xl font-bold text-primary-900 dark:text-white mb-2">${svc.title}</h3><p class="text-sm text-slate-500">${svc.description}</p></div>`;
                    bookingSelect.innerHTML += `<option value="${svc.title}">${svc.title}</option>`;
                });
            }

            const articlesGrid = document.getElementById('dynamicArticlesGrid');
            if(articlesGrid) {
                articlesGrid.innerHTML = '';
                siteData.articles.forEach(art => {
                    articlesGrid.innerHTML += `<div class="bg-white dark:bg-primary-900 p-6 rounded-2xl shadow-md border"><span class="text-xs text-gold-600 font-bold block mb-2">${art.category}</span><h3 class="font-bold text-base text-primary-950 dark:text-white mb-2">${art.title}</h3><p class="text-xs text-slate-500 mb-4">${art.summary}</p><button onclick="readFullArticle('${art.id}')" class="w-full py-2 bg-primary-100 dark:bg-primary-950 text-primary-800 text-xs font-bold rounded-xl hover:bg-gold-600 hover:text-white transition-all">اقرأ المقالة</button></div>`;
                });
            }
        }

        function handleAdminPanelClick() { isAdminLoggedIn ? toggleAdminPanel() : openAdminLoginModal(); }
        function openAdminLoginModal() { document.getElementById('adminLoginModal').classList.replace('hidden', 'flex'); }
        function closeAdminLoginModal() { document.getElementById('adminLoginModal').classList.replace('flex', 'hidden'); }
        
        function handleAdminLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value.trim();
            const pass = document.getElementById('loginPassword').value;
            if (email === ADMIN_EMAIL && pass === siteData.contact.password) {
                isAdminLoggedIn = true; closeAdminLoginModal(); toggleAdminPanel();
            } else { alert('فشل التحقق السيادي!'); }
        }

        function toggleAdminPanel() { const p = document.getElementById('adminPanel'); p.classList.toggle('hidden'); p.classList.toggle('flex'); }
        function switchAdminTab(t) { document.querySelectorAll('.admin-tab').forEach(btn => btn.classList.remove('active', 'border-gold-500', 'text-gold-600')); document.querySelectorAll('.admin-sect').forEach(s => s.classList.add('hidden')); document.getElementById('tab-'+t).classList.add('active', 'border-gold-500', 'text-gold-600'); document.getElementById('admin-sect-'+t).classList.remove('hidden'); }
        
        function saveAndApplyCmsChanges() {
            siteData.general.logoMain = document.getElementById('inpLogoMain').value;
            siteData.general.heroTitle = document.getElementById('inpHeroTitle').value;
            siteData.general.heroDescription = document.getElementById('inpHeroDesc').value;
            localStorage.setItem('salah_office_cms_state', JSON.stringify(siteData));
            renderAllCmsElements(); toggleAdminPanel();
        }
        function toggleTheme() { document.documentElement.classList.toggle('dark'); }
        function toggleMobileMenu() { document.getElementById('mobileMenu').classList.toggle('hidden'); }
    </script>
</body>
</html>
