            const savedState = localStorage.getItem('salah_office_cms_state');
            if (savedState) {
                try {
                    siteData = JSON.parse(savedState);
                } catch (e) {
                    siteData = JSON.parse(JSON.stringify(DEFAULT_SITE_DATA));
                }
            } else {
                siteData = JSON.parse(JSON.stringify(DEFAULT_SITE_DATA));
            }
            renderAllCmsElements();
        }

