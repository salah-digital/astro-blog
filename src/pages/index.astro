                        <!-- Main Image call. Direct Fallback to Unsplash if Salah.jpg is not yet uploaded on GitHub -->
                        <img id="heroImageDisplay" src="./Salah.jpg" alt="[صورة المستشار صلاح حسن إبراهيم]" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=600&auto=format&fit=crop';" class="w-28 h-28 rounded-full border-4 border-gold-500/50 object-cover shadow-lg mx-auto mt-4 transition-all hover:scale-105 duration-300">
                        
                        <div class="space-y-1 relative z-10">
                            <h3 id="heroCardName" class="text-lg font-bold text-white">المستشار صلاح حسن إبراهيم</h3>
                            <p id="heroCardTitle" class="text-xs text-gold-400 font-semibold leading-normal">خبير السيادة الرقمية وإدارة السمعة المؤسسية</p>
                        </div>
                        
                        <div class="bg-primary-950/80 border border-primary-800/60 p-4 rounded-xl max-w-xs mx-auto mb-2">
                            <p id="heroQuote" class="text-[11px] text-slate-300 italic leading-relaxed">"التحول الرقمي وحماية السمعة والسيادة الرقمية ليست مجرد أدوات تقنية، بل هي حجر الزاوية لحماية ريادة المؤسسة وبناء ثقة مستدامة."</p>
                        </div>
                    </div>
                </div>
