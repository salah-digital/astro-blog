                <!-- Facts -->
                <div class="grid grid-cols-3 gap-4 pt-8 border-t border-primary-200/50 dark:border-primary-800/50 max-w-md mx-auto lg:mx-0">
                    <div>
                        <span class="block text-2xl sm:text-3xl font-extrabold text-gold-600 dark:text-gold-400">+15</span>
                        <span class="text-xs sm:text-sm text-slate-500 dark:text-slate-400">سنة خبرة</span>
                    </div>
                    <div>
                        <span class="block text-2xl sm:text-3xl font-extrabold text-gold-600 dark:text-gold-400">+250</span>
