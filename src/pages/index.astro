    <section id="assessment" class="py-20 bg-primary-100/30 dark:bg-primary-950/40">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-2xl mx-auto mb-12 space-y-3">
                <span class="text-sm font-bold text-gold-600 dark:text-gold-400 block"><i class="fa-solid fa-gauge-high ml-1"></i>تقييم فوري</span>
                <h2 class="text-3xl font-extrabold text-primary-950 dark:text-white">مقياس النضج الرقمي للمؤسسات</h2>
            </div>
            <div class="bg-white dark:bg-primary-900 border border-primary-200 dark:border-primary-800 rounded-3xl p-6 sm:p-10 shadow-xl relative overflow-hidden">
                <div class="w-full bg-primary-100 dark:bg-primary-950 h-2 rounded-full mb-8"><div id="quizProgress" class="bg-gradient-to-r from-gold-500 to-amber-500 h-2 rounded-full transition-all" style="width: 20%;"></div></div>
                <div id="quizWindow">
                    <div class="quiz-step active space-y-6" data-step="1">
                        <span class="text-gold-600 font-bold">السؤال 1 من 5</span>
                        <h3 class="text-lg font-bold">هل تمتلك مؤسستك تحكماً برمجياً مستقلاً في موقعها وتطبيقاتها؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(1, 3)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نعم، نمتلك الشيفرة المصدرية والاستضافة بالكامل.</button>
                            <button onclick="nextQuizStep(1, 2)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نمتلك الموقع ولكن نعتمد على منصات جاهزة ومغلقة.</button>
                            <button onclick="nextQuizStep(1, 0)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">لا، نعتمد على شبكات التواصل الاجتماعي فقط للتواجد.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="2">
                        <span class="text-gold-600 font-bold">السؤال 2 من 5</span>
                        <h3 class="text-lg font-bold">كيف تُدار العمليات الإدارية وحوكمة البيانات داخل مؤسستك؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(2, 3)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">أتمتة كاملة وحفظ سحابي آمن يضمن السيادة التامة للبيانات.</button>
                            <button onclick="nextQuizStep(2, 2)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نصف مؤتمتة، نستخدم بعض الأدوات البسيطة وجداول إكسل.</button>
                            <button onclick="nextQuizStep(2, 0)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">يدوياً بالكامل عن طريق الملفات الورقية والأرشفة التقليدية.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="3">
                        <span class="text-gold-600 font-bold">السؤال 3 من 5</span>
                        <h3 class="text-lg font-bold">هل تملكون نظاماً لرصد السمعة المؤسسية وإدارة الأزمات الإعلامية؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(3, 3)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نعم، لدينا أدوات رصد آلية لآراء الجمهور وبروتوكولات استباقية.</button>
                            <button onclick="nextQuizStep(3, 1)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نتابع بشكل بسيط وغير مستمر ردود الفعل دون خطة طوارئ.</button>
                            <button onclick="nextQuizStep(3, 0)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">لا نملك أي رصد للسمعة الرقمية ونتعامل مع الأزمات بعشوائية.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="4">
                        <span class="text-gold-600 font-bold">السؤال 4 من 5</span>
                        <h3 class="text-lg font-bold">ما هي آليات حماية وتأمين البنية التحتية والبيانات بمؤسستك؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(4, 3)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نطبق جدران حماية وسياسات أمان سيبراني صارمة مع نسخ دوري.</button>
                            <button onclick="nextQuizStep(4, 1)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نعتمد على برامج حماية الأجهزة العادية دون سياسات متكاملة.</button>
                            <button onclick="nextQuizStep(4, 0)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">لا توجد أي برمجيات أو خطط لحماية البيانات أو الأمن السيبراني.</button>
                        </div>
                    </div>
                    <div class="quiz-step hidden space-y-6" data-step="5">
                        <span class="text-gold-600 font-bold">السؤال 5 من 5</span>
                        <h3 class="text-lg font-bold">كيف تنظر الإدارة العليا للسيادة الرقمية وحفظ أمن الأصول التكنولوجية؟</h3>
                        <div class="grid grid-cols-1 gap-3">
                            <button onclick="nextQuizStep(5, 3)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نراها ضرورة سيادية وأمنية قصوى ونخصص لها ميزانية ثابتة.</button>
                            <button onclick="nextQuizStep(5, 1)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نراها هامة لحماية العمليات ولكن الميزانية المخصصة لها محدودة.</button>
                            <button onclick="nextQuizStep(5, 0)" class="w-full text-right p-4 rounded-xl border bg-white dark:bg-primary-950 font-semibold hover:border-gold-500">نعتبرها بنداً تقنياً مكلفاً لا تقع أهميته ضمن الخطط الحالية.</button>
                        </div>
                    </div>
                    <div id="quizResult" class="hidden text-center space-y-6">
                        <div class="w-24 h-24 rounded-full bg-gold-100 flex items-center justify-center mx-auto text-4xl shadow-lg border text-gold-600"><i class="fa-solid fa-trophy"></i></div>
                        <div><h3 class="text-2xl font-bold">تم احتساب نضجك الرقمي بنجاح!</h3><p class="text-lg mt-2">مجموع نقاطك: <span id="quizScoreDisplay" class="font-bold text-gold-600">0</span> / 15</p></div>
                        <div class="p-6 bg-white dark:bg-primary-950 border rounded-2xl text-right max-w-xl mx-auto">
                            <h4 id="resultLevelTitle" class="font-bold text-xl text-primary-900 dark:text-gold-400"></h4>
                            <p id="resultLevelDesc" class="text-sm mt-2"></p>
                            <div class="border-t pt-4 mt-2"><h5 class="font-bold text-sm text-gold-600">💡 نصيحة المستشار الفورية:</h5><p id="resultAdvice" class="text-xs mt-1"></p></div>
                        </div>
